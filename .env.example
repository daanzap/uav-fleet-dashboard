VITE_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# For running migrations: npm run db:migrate:all
# Get from: Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres.[REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Optional: enable authenticated E2E tests (e2e/dashboard.spec.js). Without these, 4 tests are skipped.
# E2E_AUTH_EMAIL=your-test-user@example.com
# E2E_AUTH_PASSWORD=your-test-password
